# OMEGA-ULTIMATE-FUSION-V∞ — Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to git

# ── Core ──────────────────────────────────────────────
INITIAL_EQUITY_USD=3570
CYCLE_INTERVAL_SECONDS=30
API_PORT=8000

# ── Database ──────────────────────────────────────────
POSTGRES_PASSWORD=changeme_strong_password_here

# ── Redis ─────────────────────────────────────────────
REDIS_PASSWORD=changeme_redis_password_here

# ── RabbitMQ ──────────────────────────────────────────
RABBITMQ_PASSWORD=changeme_rabbit_password_here

# ── Grafana ───────────────────────────────────────────
GRAFANA_PASSWORD=changeme_grafana_password_here

# ── Telegram ──────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Twitter / X ───────────────────────────────────────
TWITTER_BEARER_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# ── Webhook ───────────────────────────────────────────
WEBHOOK_SECRET=changeme_webhook_secret_here

# ── DigitalOcean Spaces (backups) ─────────────────────
DO_SPACES_KEY=
DO_SPACES_SECRET=
DO_SPACES_BUCKET=omega-backups
DO_SPACES_ENDPOINT=nyc3.digitaloceanspaces.com
