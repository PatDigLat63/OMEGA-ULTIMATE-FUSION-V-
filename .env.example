# =============================================================================
# 🔱 OMEGA COMPLETE TRADING FORTRESS — ENVIRONMENT CONFIGURATION
# =============================================================================
# INSTRUCTIONS:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in EVERY value below in the new .env file
#   3. NEVER commit the .env file — it is gitignored for your protection
# =============================================================================

# ─── CLOUD INFRASTRUCTURE ───────────────────────────────────────────────────
# DigitalOcean API token (generate at https://cloud.digitalocean.com/account/api/tokens)
DIGITALOCEAN_API_TOKEN=<your_digitalocean_api_token>

# Server details
DROPLET_IP=<your_droplet_ip>
DOMAIN_NAME=<your_domain_name>

# ─── DATABASE ────────────────────────────────────────────────────────────────
# PostgreSQL connection details — use strong, unique values
DB_NAME=omega_fortress_db
DB_USER=omega_keystone
DB_PASSWORD=<generate_strong_password>

# ─── MONITORING ──────────────────────────────────────────────────────────────
# Grafana admin password — use strong, unique value
GRAFANA_ADMIN_PASSWORD=<generate_strong_password>

# ─── TELEGRAM INTEGRATION ────────────────────────────────────────────────────
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=<your_telegram_bot_token>

# ─── SOCIAL / NOTIFICATION INTEGRATIONS ─────────────────────────────────────
WHATSAPP_API_KEY=<your_whatsapp_api_key>
X_TWITTER_API_KEY=<your_twitter_api_key>
X_TWITTER_API_SECRET=<your_twitter_api_secret>
X_TWITTER_ACCESS_TOKEN=<your_twitter_access_token>
X_TWITTER_ACCESS_SECRET=<your_twitter_access_secret>
UPTIMEROBOT_API_KEY=<your_uptimerobot_api_key>

# ─── ORACLE / DATA PROVIDERS ─────────────────────────────────────────────────
# Helius (https://helius.dev)
HELIUS_API_KEY=<your_helius_api_key>
# Birdeye (https://birdeye.so)
BIRDEYE_API_KEY=<your_birdeye_api_key>

# ─── AGENT API KEYS ──────────────────────────────────────────────────────────
# Each agent has its own unique API key for inter-service authentication
PATRICK_API_KEY=<generate_uuid>
HASHIM_API_KEY=<generate_uuid>
DJ_API_KEY=<generate_uuid>
BOSSMAN_API_KEY=<generate_uuid>

# ─── WALLET PRIVATE KEYS (CRITICAL — KEEP SECURE) ───────────────────────────
# WARNING: These keys control real funds. Never share or commit them.
# Use hardware wallets or a secrets manager (e.g. HashiCorp Vault) in production.
WALLET_KEY_PATRICK=<wallet_private_key_for_patrick_agent>
WALLET_KEY_HASHIM=<wallet_private_key_for_hashim_agent>
WALLET_KEY_BOSSMAN=<wallet_private_key_for_bossman_agent>
WALLET_KEY_DJ=<wallet_private_key_for_dj_executor>

# ─── LIQUIDIUM LOAN STATUS ───────────────────────────────────────────────────
LIQUIDIUM_LOAN_LQ004_STATUS=PENDING
